# Use este arquivo apenas para execução local. No HCP Terraform, crie as mesmas
# chaves como Terraform variables no workspace lombada-prod.

railway_project_id   = "00000000-0000-0000-0000-000000000000"
railway_service_id   = "00000000-0000-0000-0000-000000000000"
railway_workspace_id = ""
railway_project_name = "authentic-joy"
railway_service_name = "Lombada"

cloudflare_zone_id       = "00000000000000000000000000000000"
cloudflare_proxy_enabled = false

app_domain   = "lombada.app"
app_base_url = "https://lombada.app"
repo_url     = "trevisollinux/Lombada"
repo_branch  = "main"

# Tokens não entram aqui. Use variáveis de ambiente:
# RAILWAY_TOKEN
# CLOUDFLARE_API_TOKEN
